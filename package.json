{
  "name": "headless-ui-root",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "cd apps/playground && bun run dev && cd packages/vue && bun run dev",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^6.0.2"
  }
}